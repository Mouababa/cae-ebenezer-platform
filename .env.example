# ── App ──────────────────────────────────────────────────────────
APP_ID=cae-ebenezer
APP_SECRET=change-this-to-a-long-random-secret-min-32-chars

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL=mysql://user:password@localhost:3306/cae_ebenezer

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-another-long-random-secret

# ── Resident Session ─────────────────────────────────────────────
SESSION_SECRET=change-this-too

# ── Google Sheets ────────────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEETS_ID=your-google-sheet-id-here

# ── Google Calendar ──────────────────────────────────────────────
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com

# ── KIMI OAuth (optional, legacy) ───────────────────────────────
KIMI_AUTH_URL=
KIMI_OPEN_URL=
VITE_KIMI_AUTH_URL=
VITE_APP_ID=

# ── Admin ────────────────────────────────────────────────────────
OWNER_UNION_ID=
